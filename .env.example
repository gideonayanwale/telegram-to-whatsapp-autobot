# ══════════════════════════════════════════════════════════════
#  TELEGRAM → WHATSAPP FORWARDER — ENVIRONMENT VARIABLES
#  Copy this file to your project root and fill in every value.
#  NEVER commit this file to Git — add .env to your .gitignore
# ══════════════════════════════════════════════════════════════


# ─────────────────────────────────────────────
# TELEGRAM CLIENT API
# Get these from https://my.telegram.org
#   1. Log in with your phone number
#   2. Click "API development tools"
#   3. Create an app (any name is fine)
#   4. Copy App api_id and App api_hash below
# ─────────────────────────────────────────────

TELEGRAM_API_ID=your_api_id_here
# Example: 12345678

TELEGRAM_API_HASH=your_api_hash_here
# Example: a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4

TELEGRAM_PHONE=your_phone_number_here
# Your personal Telegram phone number in international format
# Example: +2348012345678


# ─────────────────────────────────────────────
# WHATSAPP BUSINESS API (Meta)
# Get these from https://developers.facebook.com
#   1. Create a Business app
#   2. Add WhatsApp product
#   3. Go to WhatsApp → API Setup
#   4. Copy Phone Number ID and generate a
#      permanent System User Access Token
# ─────────────────────────────────────────────

WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
# Found in Meta Developer Dashboard → WhatsApp → API Setup
# Example: 109283746512938

WHATSAPP_ACCESS_TOKEN=your_access_token_here
# Use a PERMANENT token from a System User (not the temporary one)
# Temporary tokens expire in 24hrs and will break the bot
# How to get a permanent token:
#   Business Settings → System Users → Add → Generate Token
#   Select your WhatsApp app and grant whatsapp_business_messaging permission
# Example: EAAGm0PX4ZCpsBAKZB...
