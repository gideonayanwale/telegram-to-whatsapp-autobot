# Telegram Bot (still needed for the bot token)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Telegram API credentials (from my.telegram.org)
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash
TELEGRAM_PHONE=+2348012345678       # your personal Telegram phone number

# Your channel username or ID to listen to
TELEGRAM_CHANNEL=@yourchannelusername

# WhatsApp
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_meta_access_token
WHATSAPP_RECIPIENT=2348012345678    # number to forward to (no + sign)